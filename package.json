{
  "name": "mytravaly-admin-automation",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript Playwright automation suite for the MTIndia/MyTravaly admin deployment.",
  "scripts": {
    "test": "playwright test",
    "test:unit": "playwright test --project=unit",
    "test:integration": "playwright test --project=integration",
    "test:e2e": "playwright test --project=chromium",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report reports/playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/node": "22.10.2",
    "typescript": "5.7.2"
  }
}
